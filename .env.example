# Copy this file to .env.local and fill in real values.
# .env.example is safe to commit — it contains NO real secrets.
#
# To pull all values from Vercel Dashboard automatically:
#   npx vercel env pull .env.local

# ── Database ──────────────────────────────────────────────────────────────────
# Prisma Postgres connection string (or any PostgreSQL provider).
# Get it from: https://console.prisma.io → your project → Connection string
DATABASE_URL=postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require

# ── Auth.js v5 ────────────────────────────────────────────────────────────────
# Generate a strong secret with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Google OAuth Provider
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
