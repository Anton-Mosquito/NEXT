{
  "name": "finance-dashboard-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "anal yze": "ANALYZE=true npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --ci --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "db:migrate": "tsx --env-file=.env.local src/shared/lib/db-migrate.ts",
    "db:migrate:kysely": "tsx --env-file=.env.local src/shared/lib/kysely-migrate.ts",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "vercel:pull": "vercel env pull .env.local",
    "db:setup": "npm run db:migrate",
    "prepare": "husky",
    "commitlint": "commitlint --edit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@auth/kysely-adapter": "^1.11.2",
    "@hookform/resolvers": "^5.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "kysely": "^0.28.16",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-auth": "beta",
    "pg": "^8.20.0",
    "postcss": "^8.5.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-redux": "^9.2.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.4.0",
    "@next/bundle-analyzer": "^16.2.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "^16.2.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.3",
    "prettier": "^3.8.3",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vercel": "^51.2.1",
    "vitest": "^4.1.4",
    "whatwg-fetch": "^3.6.20"
  },
  "overrides": {
    "@tootallnate/once": ">=3.0.1",
    "cookie": ">=0.7.2",
    "minimatch": ">=10.2.3",
    "path-to-regexp": ">=8.3.1",
    "smol-toml": ">=1.6.1",
    "srvx": ">=0.11.13",
    "tar": ">=7.5.11",
    "@vercel/static-config": {
      "ajv": ">=8.17.2"
    },
    "@vercel/node": {
      "undici": ">=6.24.0"
    }
  }
}
